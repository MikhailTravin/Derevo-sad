<div id="review" aria-hidden="true" class="popup popup-forms">
    <div class="popup__wrapper">
        <div class="popup__content">
            <div data-close class="popup__close">
                <svg aria-hidden="true" width="12" height="12">
                    <use xlink:href="img/sprite.svg#close"></use>
                </svg>
            </div>
            <div class="popup-forms__body">
                <div class="popup-forms__top">
                    <div class="popup-forms__title">Оставить отзыв</div>
                </div>
                <form action="#" class="form">
                    <div class="form__inputs">
                        <div class="form__input">
                            <input data-required autocomplete="off" type="text" name="form[1]" placeholder="Ваше имя"
                                class="input">
                        </div>
                        <div class="form__input">
                            <input data-required autocomplete="off" type="text" name="form[1]" placeholder="Email"
                                class="input">
                        </div>
                        <div class="form__input">
                            <textarea data-required placeholder="Ваш отзыв" class="input textarea"
                                name="form[1]"></textarea>
                        </div>
                    </div>
                    <div class="form__rating">
                        <span>Поставьте оценку:</span>
                        <div data-rating="set" data-rating-size="5" data-rating-value="0" class="rating">
                        </div>
                    </div>
                    <div class="form__bottom">
                        <button type="submit" class="btn">
                            <span>Отправить</span>
                            <svg aria-hidden="true" width="21" height="13">
                                <use xlink:href="img/sprite.svg#arrow1"></use>
                            </svg>
                        </button>
                        <div class="form__text">
                            Нажимая на кнопку “Отправить” вы соглашаетесь с <a href="./">политикой
                                конфиденциальности</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>